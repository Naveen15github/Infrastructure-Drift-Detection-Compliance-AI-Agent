# ============================================================
# Self-Healing Terraform Drift Detection Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ----------------------------------------------------------
# Groq API Key (primary LLM provider)
# Get yours at https://console.groq.com/keys
# ----------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here

# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# ----------------------------------------------------------
# OpenRouter API Keys (legacy/fallback - optional)
# Get yours at https://openrouter.ai/keys
# ----------------------------------------------------------
# OPENROUTER_API_KEY_1=sk-or-v1-your-key-here
# OPENROUTER_API_KEY_2=sk-or-v1-your-key-here
# OPENROUTER_API_KEY_3=sk-or-v1-your-key-here

# OPENROUTER_MODEL=meta-llama/llama-3.2-1b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ----------------------------------------------------------
# Slack Webhook URL
# Create an incoming webhook app at https://api.slack.com/apps
# and paste the generated URL here.
# ----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_WEBHOOK_TOKEN

# Optional: Terraform Cloud workspace URL for "View Details" button in Slack
# TERRAFORM_CLOUD_WORKSPACE_URL=https://app.terraform.io/app/myorg/workspaces/drift-agent

# ----------------------------------------------------------
# AWS Credentials
# Required for terraform plan/apply and CloudTrail lookups.
# Grant the IAM user/role the permissions described in README.md.
# ----------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ----------------------------------------------------------
# Terraform Configuration
# ----------------------------------------------------------
TERRAFORM_DIR=terraform

# Optional timeout overrides (seconds)
# TERRAFORM_TIMEOUT_PLAN=300
# TERRAFORM_TIMEOUT_APPLY=600

# ----------------------------------------------------------
# Risk Threshold
# Drift with risk_score <= this value AND risk_level=LOW will
# be auto-applied. All others are escalated to Slack.
# ----------------------------------------------------------
# RISK_AUTO_APPLY_THRESHOLD=30

# ----------------------------------------------------------
# CloudTrail
# How many hours back to search for the actor who made the change
# ----------------------------------------------------------
# CLOUDTRAIL_LOOKBACK_HOURS=24
